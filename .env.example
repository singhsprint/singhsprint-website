# Meta Conversions API (CAPI) - SERVER-SIDE SECRETS
# -------------------------------------------------------------------------
# Copy this file to .env for LOCAL development, OR set each variable in
# Vercel Dashboard -> Project -> Settings -> Environment Variables for prod.
# Never commit .env. It is already gitignored.
#
# Rotation: when a token/code changes, update ONLY in Vercel env vars;
# the client-side pixel-config.js holds only the non-secret PIXEL_ID.

# Your Meta Pixel ID (15-16 digits). MUST match window.SP_PIXEL_ID in pixel-config.js
META_PIXEL_ID=000000000000000

# CAPI access token - generate in Events Manager:
#   Data Sources -> <your Pixel> -> Settings tab -> "Generate access token"
META_CAPI_ACCESS_TOKEN=EAA_REPLACE_ME

# OPTIONAL - only set while verifying in Events Manager "Test events" tab.
# Paste the code shown there (e.g. TEST12345). Remove for production traffic
# so real events start counting against your dataset.
META_TEST_EVENT_CODE=


# =========================================================================
# Customer accounts (Supabase Auth + Stripe)
# =========================================================================
# Same Supabase project as singhsprint-crm. Customers sign in with email
# OTP or phone OTP — no password. Card details are tokenized by Stripe; we
# never see a PAN. A SECOND "payment password" gates saved-card use.

# ---- Public (safe to expose to the browser) ----
# These are read by /account/*.html via the static config block we inject
# at build time. The anon key is rate-limited and RLS-protected — exposing
# it is the intended Supabase pattern. Do NOT expose any *_SERVICE_ROLE_KEY.
PUBLIC_SUPABASE_URL=https://ptrqsjexrbyupexhcjdr.supabase.co
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# ---- Server-only (Vercel env vars; never bundle into the browser) ----
# Service-role key lets the serverless API insert saved_cards rows from
# the Stripe webhook (RLS denies authenticated INSERTs by design).
SUPABASE_URL=https://ptrqsjexrbyupexhcjdr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
# Stripe → Developers → Webhooks → endpoint → "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Server-side HMAC key used to sign the short-lived "payment-unlock" token
# the API issues after the user enters their payment password. Generate
# with: openssl rand -hex 32   — rotate to invalidate every outstanding
# token at once. Sign-in sessions are NOT affected by rotation.
PAYMENT_UNLOCK_SECRET=
# How long an unlock token is valid for, in seconds. Default 10 minutes.
PAYMENT_UNLOCK_TTL_SECONDS=600
