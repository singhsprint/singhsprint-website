# Meta Conversions API (CAPI) - SERVER-SIDE SECRETS
# -------------------------------------------------------------------------
# Copy this file to .env for LOCAL development, OR set each variable in
# Vercel Dashboard -> Project -> Settings -> Environment Variables for prod.
# Never commit .env. It is already gitignored.
#
# Rotation: when a token/code changes, update ONLY in Vercel env vars;
# the client-side pixel-config.js holds only the non-secret PIXEL_ID.

# Your Meta Pixel ID (15-16 digits). MUST match window.SP_PIXEL_ID in pixel-config.js
META_PIXEL_ID=000000000000000

# CAPI access token - generate in Events Manager:
#   Data Sources -> <your Pixel> -> Settings tab -> "Generate access token"
META_CAPI_ACCESS_TOKEN=EAA_REPLACE_ME

# OPTIONAL - only set while verifying in Events Manager "Test events" tab.
# Paste the code shown there (e.g. TEST12345). Remove for production traffic
# so real events start counting against your dataset.
META_TEST_EVENT_CODE=
