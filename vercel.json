{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self'; base-uri 'self'; object-src 'none'" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, s-maxage=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/favicon-180.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, s-maxage=86400" }
      ]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, s-maxage=86400" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/guides/about.html",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/guides/about",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/industries/:slug.html",
      "destination": "/industries/:slug",
      "permanent": true
    },
    {
      "source": "/guides/:slug.html",
      "destination": "/guides/:slug",
      "permanent": true
    },
    {
      "source": "/businesses/:slug.html",
      "destination": "/businesses/:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/fr/images/:path*",
      "destination": "/images/:path*"
    },
    {
      "source": "/order/:token",
      "destination": "/order.html"
    },
    {
      "source": "/join",
      "destination": "/account/join"
    },
    {
      "source": "/api/account/credits",
      "destination": "/api/account/referral?view=credits"
    },
    {
      "source": "/api/account/my-program",
      "destination": "/api/account/programs?action=my-program"
    },
    {
      "source": "/shop/:slug",
      "destination": "/api/shop/page?slug=:slug"
    }
  ]
}
