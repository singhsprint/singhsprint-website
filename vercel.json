{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/guides/about.html",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/guides/about",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/industries/:slug.html",
      "destination": "/industries/:slug",
      "permanent": true
    },
    {
      "source": "/guides/:slug.html",
      "destination": "/guides/:slug",
      "permanent": true
    },
    {
      "source": "/businesses/:slug.html",
      "destination": "/businesses/:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/fr/images/:path*",
      "destination": "/images/:path*"
    },
    {
      "source": "/order/:token",
      "destination": "/order.html"
    },
    {
      "source": "/join",
      "destination": "/account/join"
    },
    {
      "source": "/api/account/credits",
      "destination": "/api/account/referral?view=credits"
    },
    {
      "source": "/api/account/my-program",
      "destination": "/api/account/programs?action=my-program"
    },
    {
      "source": "/shop/:slug",
      "destination": "/api/shop/page?slug=:slug"
    }
  ]
}
